{
  "name": "openwhats",
  "version": "2.0.0",
  "description": "A simple and lightweight WhatsApp desktop wrapper for Linux built with Electron.",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder --linux -p never",
    "release": "electron-builder --linux -p always",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "io.github.kevelino.openwhats",
    "productName": "OpenWhats",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "snap"
      ],
      "category": "Network"
    },
    "snap": {
      "base": "core22",
      "confinement": "strict",
      "allowNativeWayland": true,
      "grade": "stable",
      "executableArgs": [
        "--disable-gpu",
        "--disable-software-rasterizer",
        "--disable-gpu-sandbox",
        "--disable-dev-shm-usage",
        "--ozone-platform=x11"
      ],
      "environment": {
        "GSETTINGS_BACKEND": "memory"
      },
      "plugs": [
        "network",
        "network-bind",
        "opengl",
        "camera",
        "audio-playback",
        "audio-record",
        "desktop",
        "desktop-legacy",
        "x11",
        "wayland"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kevelino",
        "repo": "openwhats"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kevelino/openwhats.git"
  },
  "author": "Kevelino <justkevelino@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "electron-context-menu": "^4.1.2",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  }
}
